const express = require('express');
const multer = require('multer');
const XLSX = require('xlsx');
const fs = require('fs');
const path = require('path');

const app = express();
const upload = multer({ dest: path.join(__dirname, 'uploads_temp/'), limits: { fileSize: 50 * 1024 * 1024 } });

app.use(express.json());
app.use(express.static(path.join(__dirname, 'public')));

const DATA_FILE = path.join(__dirname, 'wtd_data.json');

function loadWTD() {
  try { 
    if (fs.existsSync(DATA_FILE)) {
      const data = fs.readFileSync(DATA_FILE, 'utf8');
      if (data && data.trim()) {
        return JSON.parse(data);
      }
    }
  } catch(e) {
    console.error('Error loading WTD data:', e.message);
  }
  return { week: '', period: '', days: {} };
}

function saveWTD(data) { 
  try {
    fs.writeFileSync(DATA_FILE, JSON.stringify(data, null, 2));
  } catch(e) {
    console.error('Error saving WTD data:', e.message);
  }
}

// =====================
// TUESDAY-MONDAY WEEK + PERIOD TRACKING
// =====================
function getWeekKey(dateStr) {
  const d = new Date(dateStr + 'T12:00:00Z');
  const day = d.getUTCDay(); // 0=Sun, 2=Tue
  // Anchor to Tuesday: roll back to most recent Tuesday
  const daysFromTue = (day + 5) % 7; // days since last Tuesday
  const tue = new Date(d);
  tue.setUTCDate(d.getUTCDate() - daysFromTue);
  return tue.toISOString().split('T')[0];
}

// Period = 4-week blocks starting from a known anchor
// PH fiscal year starts first Tuesday of Jan ~2024. We'll use 2024-01-02 as anchor.
function getPeriodWeek(dateStr) {
  const ANCHOR = new Date('2024-01-02T12:00:00Z'); // Known P1W1 Tuesday
  const d = new Date(dateStr + 'T12:00:00Z');
  const weekKey = getWeekKey(dateStr);
  const weekStart = new Date(weekKey + 'T12:00:00Z');
  const msPerWeek = 7 * 24 * 60 * 60 * 1000;
  const weeksSinceAnchor = Math.round((weekStart - ANCHOR) / msPerWeek);
  const totalWeeks = Math.max(0, weeksSinceAnchor);
  const period = Math.floor(totalWeeks / 4) + 1;
  const week = (totalWeeks % 4) + 1;
  return `P${period}W${week}`;
}

// =====================
// EXCEL PARSER - CORRECTED COLUMN MAPPING
// =====================
// Based on actual file analysis of PH Speed of Service report:
// Row 2 (index 1): col 23 = report date (datetime)
// Row 10 (index 9): store-level column headers
//   Col 0  = Store ID
//   Col 3  = On Time %
//   Col 8  = In Store (avg minutes, numeric)
//   Col 9  = # Del (deliveries)
//   Col 11 = Make (MM:SS string)
//   Col 13 = % < 4
//   Col 15 = Oven / Cut
//   Col 17 = Production (MM:SS string)
//   Col 19 = % < 15
//   Col 24 = Rack
// Store data rows start at row 11 (index 10)

function parseSOSExcel(filePath) {
  const wb = XLSX.readFile(filePath, { cellDates: true });
  const ws = wb.Sheets[wb.SheetNames[0]];
  const raw = XLSX.utils.sheet_to_json(ws, { header: 1, defval: null });

  let reportDate = null;
  let reportType = 'daily';

  // PRIMARY: Row 2 (index 1), Col 23 = the report date
  try {
    const dateCell = raw[1] && raw[1][23];
    if (dateCell instanceof Date) {
      const y = dateCell.getFullYear();
      const m = String(dateCell.getMonth() + 1).padStart(2, '0');
      const d = String(dateCell.getDate()).padStart(2, '0');
      reportDate = `${y}-${m}-${d}`;
    } else if (typeof dateCell === 'string') {
      const m2 = dateCell.match(/(\d{1,2})\/(\d{1,2})\/(\d{4})/);
      if (m2) reportDate = `${m2[3]}-${m2[1].padStart(2,'0')}-${m2[2].padStart(2,'0')}`;
      const m1 = dateCell.match(/(\d{4})-(\d{2})-(\d{2})/);
      if (m1) reportDate = m1[0];
    }
  } catch(e) {}

  // FALLBACK: scan first 5 rows for any date value
  if (!reportDate) {
    for (let i = 0; i < Math.min(5, raw.length); i++) {
      for (let j = 0; j < Math.min(30, (raw[i] || []).length); j++) {
        const cell = raw[i][j];
        if (cell instanceof Date && cell.getFullYear() > 2020) {
          const y = cell.getFullYear();
          const m = String(cell.getMonth() + 1).padStart(2, '0');
          const d = String(cell.getDate()).padStart(2, '0');
          reportDate = `${y}-${m}-${d}`;
          break;
        } else if (typeof cell === 'string') {
          const m2 = cell.match(/(\d{1,2})\/(\d{1,2})\/(\d{4})/);
          if (m2 && parseInt(m2[3]) > 2020) {
            reportDate = `${m2[3]}-${m2[1].padStart(2,'0')}-${m2[2].padStart(2,'0')}`;
            break;
          }
          const m1 = cell.match(/(\d{4})-(\d{2})-(\d{2})/);
          if (m1 && parseInt(m1[1]) > 2020) { reportDate = m1[0]; break; }
        }
      }
      if (reportDate) break;
    }
  }

  // Check for "week" keyword
  for (let i = 0; i < Math.min(5, raw.length); i++) {
    for (let j = 0; j < (raw[i] || []).length; j++) {
      if (typeof raw[i][j] === 'string' && raw[i][j].toLowerCase().includes('week')) {
        reportType = 'weekly';
      }
    }
  }

  const stores = [];
  for (let i = 0; i < raw.length; i++) {
    const row = raw[i];
    if (!row || !row[0] || typeof row[0] !== 'string') continue;
    // Match store IDs: S038729, S039377, S040090, S041651
    if (!row[0].match(/^S0\d{5}$/) && !row[0].match(/^S\d{6}$/)) continue;

    // Col 8 = In Store (avg minutes, numeric)
    const inStore = typeof row[8] === 'number' ? row[8] : parseFloat(row[8]);
    if (!inStore || inStore <= 0) continue;

    const estimatedLt19 = inStore <= 17 ? 90 : inStore <= 19 ? 75 : inStore <= 22 ? 55 : inStore <= 25 ? 35 : 20;

    stores.push({
      store_id:   row[0].trim(),
      on_time:    row[3]  || null,        // Col 3  = On Time %
      in_store:   inStore,                 // Col 8  = In Store (avg minutes)
      deliveries: parseInt(row[9]) || 0,  // Col 9  = # Deliveries
      make:       row[11] || null,         // Col 11 = Make (MM:SS)
      pct_lt4:    row[13] || null,         // Col 13 = % < 4
      oven_cut:   row[15] || null,         // Col 15 = Oven/Cut (MM:SS)
      production: row[17] || null,         // Col 17 = Production (MM:SS) - actual production time
      // PDF Production = Oven/Cut time (col 15) which matches the Above Store report
      pct_lt15:   row[19] || null,         // Col 19 = % < 15
      rack:       row[24] || null,         // Col 24 = Rack
      ist_lt19_pct:   estimatedLt19,
      ist_gt25_count: inStore > 25 ? Math.round((inStore - 25) / 3) : 0
    });
  }

  console.log(`Excel parsed: ${stores.length} stores, date=${reportDate}`);
  if (stores.length > 0) {
    console.log(`  Sample: ${stores[0].store_id} IST=${stores[0].in_store} Make=${stores[0].make} Prod=${stores[0].production}`);
  }

  return { stores, reportDate, reportType, source: 'excel' };
}

// =====================
// PDF PARSER — via Claude API
// =====================
async function parseAboveStorePDF(filePath) {
  try {
    const apiKey = process.env.ANTHROPIC_API_KEY;
    if (!apiKey) {
      console.error('ANTHROPIC_API_KEY not set - PDF parsing disabled');
      return { 
        stores: [], 
        reportDate: null, 
        reportType: 'daily', 
        source: 'pdf', 
        error: 'PDF parsing requires ANTHROPIC_API_KEY environment variable' 
      };
    }

    const fileBuffer = fs.readFileSync(filePath);
    const base64Data = fileBuffer.toString('base64');

    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 4000,
        messages: [{
          role: 'user',
          content: [
            {
              type: 'document',
              source: { type: 'base64', media_type: 'application/pdf', data: base64Data }
            },
            {
              type: 'text',
              text: `Extract Speed of Service data from this Pizza Hut Above Store report. Return ONLY a JSON array with no markdown, no backticks, no explanation. Each object must have these exact keys:
{
  "store_id": "S039xxx",
  "bus_date": "MM/DD/YYYY",
  "total_orders": number,
  "ist_avg": number (average in-store time in minutes, null if not found),
  "ist_lt10_count": number, "ist_lt10_pct": number,
  "ist_1014_count": number, "ist_1014_pct": number,
  "ist_1518_count": number, "ist_1518_pct": number,
  "ist_1925_count": number, "ist_1925_pct": number,
  "ist_gt25_count": number, "ist_gt25_pct": number,
  "ist_lt19_count": number, "ist_lt19_pct": number
}
Note: ist_lt19 = sum of lt10 + 1014 + 1518 buckets. Calculate it if not explicit.
Return [] if no store data found.`
            }
          ]
        }]
      })
    });

    if (!response.ok) {
      const errText = await response.text();
      console.error('Claude API error:', response.status, errText);
      return { 
        stores: [], 
        reportDate: null, 
        reportType: 'daily', 
        source: 'pdf', 
        error: `Claude API error ${response.status}` 
      };
    }

    const apiResult = await response.json();
    const rawText = apiResult.content?.map(c => c.text || '').join('').trim();

    // Strip any accidental markdown
    let cleaned = rawText.replace(/^```json\s*/i, '').replace(/^```\s*/, '').replace(/```\s*$/, '').trim();
    
    // Try to find JSON array in the response
    const jsonMatch = cleaned.match(/\[[\s\S]*\]/);
    if (jsonMatch) {
      cleaned = jsonMatch[0];
    }
    
    let stores;
    try {
      stores = JSON.parse(cleaned);
    } catch(parseErr) {
      console.error('Failed to parse Claude response as JSON:', cleaned.substring(0, 200));
      return { 
        stores: [], 
        reportDate: null, 
        reportType: 'daily', 
        source: 'pdf', 
        error: 'Failed to parse Claude response as JSON' 
      };
    }

    if (!Array.isArray(stores)) {
      console.error('PDF parse returned non-array:', typeof stores);
      return { 
        stores: [], 
        reportDate: null, 
        reportType: 'daily', 
        source: 'pdf', 
        error: 'PDF parse returned non-array' 
      };
    }

    // Derive report date from first store's bus_date
    let reportDate = null;
    for (const s of stores) {
      if (s.bus_date) {
        const parts = s.bus_date.split('/');
        if (parts.length === 3) {
          const yr = parts[2].length === 2 ? '20' + parts[2] : parts[2];
          reportDate = `${yr}-${parts[0].padStart(2, '0')}-${parts[1].padStart(2, '0')}`;
          break;
        }
      }
    }

    // Recalculate ist_lt19 from buckets if missing or zero
    stores.forEach(s => {
      const bucketCount = (s.ist_lt10_count || 0) + (s.ist_1014_count || 0) + (s.ist_1518_count || 0);
      const bucketPct = (s.ist_lt10_pct || 0) + (s.ist_1014_pct || 0) + (s.ist_1518_pct || 0);
      if (!s.ist_lt19_count || s.ist_lt19_count === 0) s.ist_lt19_count = bucketCount;
      if (!s.ist_lt19_pct || s.ist_lt19_pct === 0) s.ist_lt19_pct = parseFloat(bucketPct.toFixed(1));
    });

    return { stores, reportDate, reportType: 'daily', source: 'pdf' };
  } catch(e) {
    console.error('PDF parse error:', e.message);
    return { stores: [], reportDate: null, reportType: 'daily', source: 'pdf', error: e.message };
  }
}

// =====================
// UPLOAD
// =====================
app.post('/api/upload', upload.array('files', 10), async (req, res) => {
  const tempFiles = req.files ? req.files.map(f => f.path) : [];
  
  try {
    if (!req.files || !req.files.length) {
      return res.status(400).json({ error: 'No files received' });
    }

    const uploaderName = req.body.uploaderName || 'Unknown';
    let wtd = loadWTD();
    const results = [];
    const errors = [];

    for (const file of req.files) {
      const isExcel = file.originalname.match(/\.xlsx?$/i);
      const isPdf = file.originalname.match(/\.pdf$/i);
      let parsed = null;

      try {
        if (isExcel) {
          parsed = parseSOSExcel(file.path);
        } else if (isPdf) {
          parsed = await parseAboveStorePDF(file.path);
        } else {
          errors.push(`${file.originalname}: unsupported file type`);
          continue;
        }
      } catch(parseErr) {
        console.error(`Parse error for ${file.originalname}:`, parseErr.message);
        errors.push(`${file.originalname}: ${parseErr.message}`);
        continue;
      }

      // Handle null/undefined parsed result
      if (!parsed) {
        errors.push(`${file.originalname}: no data returned from parser`);
        continue;
      }

      // Handle error from parser
      if (parsed.error) {
        errors.push(`${file.originalname}: ${parsed.error}`);
        if (parsed.stores && parsed.stores.length === 0) {
          // If no stores but we have an error, skip this file
          continue;
        }
      }

      if (!parsed.stores || !parsed.stores.length) {
        errors.push(`${file.originalname}: no store data found`);
        continue;
      }

      const { stores, reportDate, reportType } = parsed;

      // Use report date, fallback to today only if absolutely necessary
      const finalDate = reportDate || new Date().toISOString().split('T')[0];
      const weekKey = getWeekKey(finalDate);
      const periodWeek = getPeriodWeek(finalDate);

      // If this is a new week, reset everything
      if (wtd.week && wtd.week !== weekKey) {
        console.log(`New week detected: ${wtd.week} -> ${weekKey}, resetting data`);
        wtd = { week: weekKey, period: periodWeek, days: {} };
      }
      if (!wtd.week) wtd.week = weekKey;
      if (!wtd.period) wtd.period = periodWeek;

      // Initialize day if not exists
      if (!wtd.days[finalDate]) {
        wtd.days[finalDate] = { date: finalDate, type: reportType, uploader: uploaderName, stores: [] };
      }

      // Merge stores - replace existing stores with new data
      const existing = {};
      wtd.days[finalDate].stores.forEach(s => { existing[s.store_id] = s; });

      stores.forEach(s => {
        const align = ALIGNMENT[s.store_id];
        if (!align) return; // Skip stores not in alignment
        
        // Merge: new data takes precedence, but keep alignment info
        existing[s.store_id] = { 
          ...existing[s.store_id], // keep existing data
          ...s,                     // override with new data
          ...align                  // always update alignment
        };
      });

      wtd.days[finalDate].stores = Object.values(existing);
      
      results.push({
        file: file.originalname,
        date: finalDate,
        period: periodWeek,
        type: reportType,
        storeCount: wtd.days[finalDate].stores.length,
        source: parsed.source
      });
    }

    // Clean up temp files
    tempFiles.forEach(f => {
      try {
        if (fs.existsSync(f)) fs.unlinkSync(f);
      } catch(e) {}
    });

    saveWTD(wtd);
    const computed = computeWTD(wtd);
    return res.json({ success: true, results, errors, wtd: computed });

  } catch(e) {
    console.error('Upload route error:', e);
    tempFiles.forEach(f => {
      try {
        if (fs.existsSync(f)) fs.unlinkSync(f);
      } catch(e2) {}
    });
    return res.status(500).json({ error: e.message || 'Server error during upload' });
  }
});

app.get('/api/data', (req, res) => {
  try {
    const wtd = loadWTD();
    res.json({ wtd: computeWTD(wtd) });
  } catch(e) {
    console.error('Error in /api/data:', e);
    res.status(500).json({ error: e.message });
  }
});

app.post('/api/reset', (req, res) => {
  saveWTD({ week: '', period: '', days: {} });
  res.json({ success: true });
});

app.post('/api/ai', async (req, res) => {
  try {
    const apiKey = process.env.ANTHROPIC_API_KEY;
    if (!apiKey) {
      return res.status(400).json({ error: 'AI features require ANTHROPIC_API_KEY' });
    }
    
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: 'You are Velocity, a Pizza Hut Speed of Service intelligence agent. Be direct, specific, action-oriented. No corporate fluff. Plain text only.',
        messages: req.body.messages
      })
    });
    res.json(await response.json());
  } catch(e) {
    res.status(500).json({ error: e.message });
  }
});

// =====================
// HELPERS
// =====================
function parseTimeToMins(s) {
  if (!s || s === 'NaN' || s === '0:00' || s === '—') return 0;
  const neg = s.startsWith('-');
  const clean = s.replace('-', '').split(':');
  return (neg ? -1 : 1) * ((parseInt(clean[0]) || 0) + (parseInt(clean[1]) || 0) / 60);
}

function parsePct(s) {
  if (!s) return 0;
  return parseFloat(String(s).replace('%', '')) || 0;
}

function fmtTime(m) {
  if (!m || m <= 0) return '0:00';
  const i = Math.floor(Math.abs(m));
  const s = Math.round((Math.abs(m) - i) * 60);
  return `${m < 0 ? '-' : ''}${i}:${String(s).padStart(2, '0')}`;
}

function computeWTD(wtd) {
  const days = Object.values(wtd.days || {}).sort((a, b) => a.date.localeCompare(b.date));
  if (!days.length) return { days: [], stores: [], week: wtd.week, period: wtd.period || '' };

  const allIds = new Set();
  days.forEach(d => d.stores.forEach(s => allIds.add(s.store_id)));

  const storeWTD = [];
  for (const sid of allIds) {
    const dd = days.map(d => d.stores.find(s => s.store_id === sid)).filter(Boolean);
    if (!dd.length) continue;
    const align = ALIGNMENT[sid] || {};
    if (!align.name) continue;

    const avgIST = dd.reduce((a, s) => a + (s.ist_avg || s.in_store || 0), 0) / dd.length;
    const avgMk = dd.reduce((a, s) => a + parseTimeToMins(s.make), 0) / dd.length;
    const avgPr = dd.reduce((a, s) => a + parseTimeToMins(s.production), 0) / dd.length;
    const avgPct4 = dd.reduce((a, s) => a + parsePct(s.pct_lt4), 0) / dd.length;
    const avgPct15 = dd.reduce((a, s) => a + parsePct(s.pct_lt15), 0) / dd.length;
    const avgOT = dd.reduce((a, s) => a + parsePct(s.on_time), 0) / dd.length;

    // IST <19%: force numeric, use bucket calc as fallback if zero
    const avgLt19 = dd.reduce((a, s) => {
      let val = 0;
      if (typeof s.ist_lt19_pct === 'number' && s.ist_lt19_pct > 0) {
        val = s.ist_lt19_pct;
      } else if (typeof s.ist_lt19_pct === 'string') {
        val = parseFloat(s.ist_lt19_pct) || 0;
      }
      // Fallback: calculate from buckets if still 0
      if (val === 0) {
        val = (s.ist_lt10_pct || 0) + (s.ist_1014_pct || 0) + (s.ist_1518_pct || 0);
      }
      // Ultimate fallback: estimate from in_store time
      if (val === 0 && (s.ist_avg || s.in_store)) {
        const ist = s.ist_avg || s.in_store;
        val = ist <= 19 ? 85 : ist <= 22 ? 60 : ist <= 25 ? 40 : 25;
      }
      return a + val;
    }, 0) / dd.length;

    const avgGt25Count = dd.reduce((a, s) => a + (s.ist_gt25_count || 0), 0) / dd.length;
    const totalDel = dd.reduce((a, s) => a + (s.total_orders || s.deliveries || 0), 0);
    const last = dd[dd.length - 1];

    const daily = {};
    days.forEach(d => {
      const s = d.stores.find(s => s.store_id === sid);
      if (s) daily[d.date] = {
        in_store: s.ist_avg || s.in_store,
        make: s.make,
        production: s.production,
        on_time: s.on_time,
        deliveries: s.total_orders || s.deliveries,
        pct_lt4: s.pct_lt4,
        pct_lt15: s.pct_lt15,
        ist_lt19_pct: s.ist_lt19_pct,
        ist_gt25_count: s.ist_gt25_count,
        ist_gt25_pct: s.ist_gt25_pct
      };
    });

    // Get the last IST<19% value with proper fallback
    let lastLt19 = last.ist_lt19_pct;
    if (!lastLt19 || lastLt19 === 0) {
      lastLt19 = (last.ist_lt10_pct || 0) + (last.ist_1014_pct || 0) + (last.ist_1518_pct || 0);
    }
    if (!lastLt19 || lastLt19 === 0) {
      const ist = last.ist_avg || last.in_store;
      lastLt19 = ist <= 19 ? 85 : ist <= 22 ? 60 : ist <= 25 ? 40 : 25;
    }

    storeWTD.push({
      store_id: sid,
      name: align.name,
      area: align.area,
      area_coach: align.area_coach,
      region_coach: align.region_coach,
      days_reported: dd.length,
      wtd_in_store: Math.round(avgIST * 10) / 10,
      wtd_make: fmtTime(avgMk),
      wtd_pct_lt4: avgPct4.toFixed(1) + '%',
      wtd_production: fmtTime(avgPr),
      wtd_pct_lt15: avgPct15.toFixed(1) + '%',
      wtd_on_time: avgOT.toFixed(1) + '%',
      wtd_deliveries: totalDel,
      wtd_lt19_pct: avgLt19.toFixed(1),
      wtd_gt25_avg: avgGt25Count.toFixed(1),
      in_store: last.ist_avg || last.in_store,
      make: last.make,
      pct_lt4: last.pct_lt4,
      production: last.production,
      pct_lt15: last.pct_lt15,
      on_time: last.on_time,
      deliveries: last.total_orders || last.deliveries,
      ist_lt19_pct: typeof lastLt19 === 'number' ? lastLt19 : parseFloat(lastLt19) || 0,
      ist_gt25_count: last.ist_gt25_count || 0,
      daily
    });
  }

  return {
    week: wtd.week,
    period: wtd.period || '',
    days: days.map(d => ({ date: d.date, type: d.type, storeCount: d.stores.length, uploader: d.uploader })),
    stores: storeWTD
  };
}

